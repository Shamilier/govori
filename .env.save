# ============================================
# GovorI MVP — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ---- General ----
NODE_ENV=production

# ---- Secrets (ОБЯЗАТЕЛЬНО ПОМЕНЯТЬ!) ----
JWT_SECRET=change-me-at-least-32-characters-long-random-string
ENCRYPTION_KEY=change-me-exactly-32-chars-long!

# ---- Admin credentials (для seed) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Shamil2004!

# ---- API Server ----
API_PORT=4000
API_HOST=0.0.0.0

# ---- Public URL (как Voximplant видит ваш сервер) ----
# ОБЯЗАТЕЛЬНО для продакшена — полный HTTPS URL без trailing slash
PUBLIC_API_BASE_URL=https://api.disciplaner.online

# ---- Frontend ----
WEB_ORIGIN=https://disciplaner.online
NEXT_PUBLIC_API_URL=https://api.disciplaner.online

# ---- Database (для Docker Compose — использовать имя сервиса postgres) ----
DATABASE_URL=postgresql://govori:Shamil2004!@postgres:5432/govori

# ---- Redis (для Docker Compose — использовать имя сервиса redis) ----
REDIS_URL=redis://redis:6379

# ---- Rate Limiting ----
RATE_LIMIT_MAX=120
RATE_LIMIT_TIME_WINDOW=1 minute

# ============================================
# ПРОВАЙДЕРЫ
# ============================================

# ---- Telephony ----
TELEPHONY_PROVIDER=voximplant
VOXIMPLANT_APPLICATION_ID=
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY=
VOXIMPLANT_API_SECRET=
# Секрет для проверки запросов от Voximplant (можно любую строку)
VOXIMPLANT_WEBHOOK_SECRET=
PHONE_NUMBER_E164=+79001234567

# ---- TTS: Cartesia ----
CARTESIA_API_KEY=sk_car_WKbXACVCAJms6HyfSjWMBc
CARTESIA_VOICE_ID=0016c6f4-d9a9-4154-ab9b-7e1f1c3c483e
CARTESIA_MODEL_ID=sonic-2

# ---- LLM: OpenAI ----
LLM_PROVIDER=openai
LLM_API_KEY=
# Для Voximplant Realtime API — используется gpt-4o-realtime-preview
# Для обычных запросов (test-prompt) — используется эта модель
LLM_MODEL=gpt-4.1-mini

# ---- STT ----
STT_PROVIDER=mock
STT_API_KEY=

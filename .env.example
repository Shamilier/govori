# ============================================
# GovorI MVP — Environment Variables
# ============================================
# Copy this file to .env and fill in the values
# cp .env.example .env

# ---- General ----
NODE_ENV=production

# ---- Secrets (ОБЯЗАТЕЛЬНО ПОМЕНЯТЬ!) ----
JWT_SECRET=change-me-at-least-32-characters-long-random-string
ENCRYPTION_KEY=change-me-exactly-32-chars-long!

# ---- Admin credentials (для seed) ----
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=StrongPassword123!

# ---- API Server ----
API_PORT=4000
API_HOST=0.0.0.0

# ---- Public URL (как Voximplant видит ваш сервер) ----
# ОБЯЗАТЕЛЬНО для продакшена — полный HTTPS URL без trailing slash
PUBLIC_API_BASE_URL=https://api.yourdomain.com

# ---- Frontend ----
WEB_ORIGIN=https://yourdomain.com
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ---- Database (для Docker Compose — использовать имя сервиса postgres) ----
DATABASE_URL=postgresql://govori:Shamil2004!@postgres:5432/govori

# ---- Redis (для Docker Compose — использовать имя сервиса redis) ----
REDIS_URL=redis://redis:6379

# ---- Telegram Bot ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change-me-random-long-string
TELEGRAM_AUTH_TOKEN_TTL_MIN=15

# ---- Rate Limiting ----
RATE_LIMIT_MAX=120
RATE_LIMIT_TIME_WINDOW=1 minute

# ============================================
# ПРОВАЙДЕРЫ
# ============================================

# ---- Telephony ----
TELEPHONY_PROVIDER=voximplant
VOXIMPLANT_APPLICATION_ID=
VOXIMPLANT_ACCOUNT_ID=
VOXIMPLANT_API_KEY=
VOXIMPLANT_API_SECRET=
VOXIMPLANT_OUTBOUND_RULE_ID=
# Секрет для проверки запросов от Voximplant (можно любую строку)
VOXIMPLANT_WEBHOOK_SECRET=
PHONE_NUMBER_E164=+79001234567

# ---- Gemini (LLM + TTS + STT) ----
GEMINI_API_KEY=
GEMINI_LLM_MODEL=gemini-2.5-flash
GEMINI_TTS_MODEL=gemini-2.5-flash-preview-tts
GEMINI_TTS_VOICE=Kore
GEMINI_STT_MODEL=gemini-2.5-flash

# Legacy compatibility (optional)
LLM_PROVIDER=gemini
LLM_API_KEY=
LLM_MODEL=gemini-2.5-flash
STT_PROVIDER=gemini
STT_API_KEY=
